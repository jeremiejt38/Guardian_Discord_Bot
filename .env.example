# Environment: production (stable)
NODE_ENV=production

# Discord bot credentials — create one app per environment:
# https://discord.com/developers/applications
CLIENT_ID=
DISCORD_TOKEN=

# Optional: restrict slash command registration to a test guild
# GUILD_ID=

# Guardian admin Discord user ID (receives update/error DMs)
BOT_ADMIN_ID=

# Server secrets / encryption key
SERVER_SECRETS_KEY=

# SQLite database path (use different paths per environment)
DATABASE_PATH=./data/guardian.db

# GitHub tokens for releases (only needed on the machine that runs /release-free)
GITHUB_TOKEN=
GITHUB_FREE_RELEASE_TOKEN=
GITHUB_FREE_REPO=jeremiejt38/Guardian_Discord_Bot_Free

# To run in dev/beta mode, copy this file to .env.dev or .env.beta and fill in
# the dedicated CLIENT_ID / DISCORD_TOKEN for that environment.
# Then use: npm run start:dev   or   npm run deploy:commands:dev
